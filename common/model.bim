            "name": "fact_equipment_downtime",
            "source": {
              "type": "query",
              "query": "SELECT downtime_id, equipment_id, reason_id, date_id AS start_date_id, date_id AS end_date_id, EXTRACT(HOUR FROM start_time)::int * 60 + EXTRACT(MINUTE FROM start_time)::int AS start_time_id, EXTRACT(HOUR FROM end_time)::int * 60 + EXTRACT(MINUTE FROM end_time)::int AS end_time_id, duration_min AS duration_minutes, comment AS description FROM public.fact_equipment_downtime",
              "dataSource": "New Data Source"
            }
          }
        ],
        "annotations": [
