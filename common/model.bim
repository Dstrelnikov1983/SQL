      },
      {
        "name": "_Measures",
        "description": "Таблица мер - ключевые показатели эффективности предприятия Руда+",
        "lineageTag": "a1b2c3d4-e5f6-7890-abcd-ef1234567818",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "_MeasuresPlaceholder",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[_MeasuresPlaceholder]"
          }
        ],
        "partitions": [
          {
            "name": "_Measures",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "ROW(\"_MeasuresPlaceholder\", 0)"
            }
          }
        ],
        "measures": [
          {
            "name": "Общий объем добычи",
            "description": "Суммарный объем добытой руды в тоннах",
            "expression": "SUM('fact_production'[tons_mined])",
            "formatString": "#,##0.00",
            "lineageTag": "msr-001",
            "annotations": [
              {
                "name": "Category",
                "value": "Производство"
              }
            ]
          },
          {
            "name": "Средняя добыча за смену",
            "description": "Средний объем добычи руды за одну смену (тонн)",
            "expression": "AVERAGE('fact_production'[tons_mined])",
            "formatString": "#,##0.00",
            "lineageTag": "msr-002",
            "annotations": [
              {
                "name": "Category",
                "value": "Производство"
              }
            ]
          },
          {
            "name": "Общее время простоя",
            "description": "Суммарное время простоев оборудования в минутах",
            "expression": "SUM('fact_equipment_downtime'[duration_min])",
            "formatString": "#,##0",
            "lineageTag": "msr-003",
            "annotations": [
              {
                "name": "Category",
                "value": "Простои"
              }
            ]
          },
          {
            "name": "Общее время простоя (часы)",
            "description": "Суммарное время простоев оборудования в часах",
            "expression": "DIVIDE(SUM('fact_equipment_downtime'[duration_min]), 60)",
            "formatString": "#,##0.0",
            "lineageTag": "msr-004",
            "annotations": [
              {
                "name": "Category",
                "value": "Простои"
              }
            ]
          },
          {
            "name": "Среднее содержание Fe",
            "description": "Среднее содержание железа в пробах руды (%)",
            "expression": "AVERAGE(fact_ore_quality[fe_content])",
            "formatString": "0.00\"%\"",
            "lineageTag": "msr-005",
            "annotations": [
              {
                "name": "Category",
                "value": "Качество"
              }
            ]
          },
          {
            "name": "Количество аномалий",
            "description": "Общее количество зафиксированных аномалий датчиков",
            "expression": "COUNTROWS(FILTER(fact_equipment_telemetry, 'fact_equipment_telemetry'[is_alarm] = TRUE()))",
            "formatString": "#,##0",
            "lineageTag": "msr-006",
            "annotations": [
              {
                "name": "Category",
                "value": "Телеметрия"
              }
            ]
          },
          {
            "name": "КТГ",
            "description": "Коэффициент технической готовности = (Общее время - Время незапланированных простоев) / Общее время. Рассчитывается на основе рабочих часов за смену (12ч = 720 мин) и незапланированных простоев.",
            "expression": [
              "VAR _TotalScheduledMinutes =",
              "    CALCULATE(",
              "        COUNTROWS(fact_production) * 720",
              "    )",
              "VAR _UnplannedDowntimeMinutes =",
              "    CALCULATE(",
              "        SUM('fact_equipment_downtime'[duration_min]),",
              "        RELATEDTABLE(dim_downtime_reason),",
              "        dim_downtime_reason[is_planned] = FALSE()",
              "    )",
              "RETURN",
              "    DIVIDE(",
              "        _TotalScheduledMinutes - _UnplannedDowntimeMinutes,",
              "        _TotalScheduledMinutes",
              "    )"
            ],
            "formatString": "0.00%",
            "lineageTag": "msr-007",
            "annotations": [
              {
                "name": "Category",
                "value": "Эффективность"
              },
              {
                "name": "FullName",
                "value": "Коэффициент технической готовности"
              }
            ]
          },
          {
            "name": "OEE",
            "description": "Overall Equipment Effectiveness = Доступность x Производительность x Качество. Доступность: (Плановое время - Простои) / Плановое время. Производительность: Фактическая добыча / Нормативная добыча. Качество: Доля руды с содержанием Fe выше минимального порога.",
            "expression": [
              "VAR _TotalScheduledMinutes =",
              "    CALCULATE(",
              "        COUNTROWS(fact_production) * 720",
              "    )",
              "VAR _TotalDowntimeMinutes =",
              "    CALCULATE(",
              "        SUM('fact_equipment_downtime'[duration_min])",
              "    )",
              "VAR _Availability =",
              "    DIVIDE(",
              "        _TotalScheduledMinutes - _TotalDowntimeMinutes,",
              "        _TotalScheduledMinutes",
              "    )",
              "VAR _ActualProduction = SUM('fact_production'[tons_mined])",
              "VAR _OperatingHours = SUM(fact_production[operating_hours])",
              "VAR _NominalCapacityPerHour = 25",
              "VAR _Performance =",
              "    DIVIDE(",
              "        _ActualProduction,",
              "        _OperatingHours * _NominalCapacityPerHour",
              "    )",
              "VAR _TotalSamples = COUNTROWS(fact_ore_quality)",
              "VAR _QualitySamples =",
              "    CALCULATE(",
              "        COUNTROWS(fact_ore_quality),",
              "        fact_ore_quality[fe_content] >= 30",
              "    )",
              "VAR _Quality = DIVIDE(_QualitySamples, _TotalSamples)",
              "RETURN",
              "    _Availability * _Performance * _Quality"
            ],
            "formatString": "0.00%",
            "lineageTag": "msr-008",
            "annotations": [
              {
                "name": "Category",
                "value": "Эффективность"
              },
              {
                "name": "FullName",
                "value": "Overall Equipment Effectiveness"
              }
            ]
          },
          {
            "name": "Общий расход топлива",
            "description": "Суммарный расход топлива (литров)",
            "expression": "SUM('fact_production'[fuel_consumed_l])",
            "formatString": "#,##0.00",
            "lineageTag": "msr-009",
            "annotations": [
              {
                "name": "Category",
                "value": "Производство"
              }
            ]
          },
          {
            "name": "Удельный расход топлива",
            "description": "Расход топлива на тонну добытой руды (л/т)",
            "expression": "DIVIDE(SUM('fact_production'[fuel_consumed_l]), SUM('fact_production'[tons_mined]))",
            "formatString": "0.00",
            "lineageTag": "msr-010",
            "annotations": [
              {
                "name": "Category",
                "value": "Производство"
              }
            ]
          },
          {
            "name": "Общее количество рейсов",
            "description": "Суммарное количество рейсов техники",
            "expression": "SUM(fact_production[trips_count])",
            "formatString": "#,##0",
            "lineageTag": "msr-011",
            "annotations": [
              {
                "name": "Category",
                "value": "Производство"
              }
            ]
          },
          {
            "name": "Средняя загрузка за рейс",
            "description": "Средний объем руды на один рейс (тонн)",
            "expression": "DIVIDE(SUM('fact_production'[tons_mined]), SUM(fact_production[trips_count]))",
            "formatString": "0.00",
            "lineageTag": "msr-012",
            "annotations": [
              {
                "name": "Category",
                "value": "Производство"
              }
            ]
          },
          {
            "name": "Доля плановых простоев",
            "description": "Доля плановых простоев от общего времени простоев",
            "expression": [
              "DIVIDE(",
              "    CALCULATE(",
              "        SUM('fact_equipment_downtime'[duration_min]),",
              "        RELATEDTABLE(dim_downtime_reason),",
              "        dim_downtime_reason[is_planned] = TRUE()",
              "    ),",
              "    SUM('fact_equipment_downtime'[duration_min])",
              ")"
            ],
            "formatString": "0.00%",
            "lineageTag": "msr-013",
            "annotations": [
              {
                "name": "Category",
                "value": "Простои"
              }
            ]
          },
          {
            "name": "Среднее содержание SiO2",
            "description": "Среднее содержание кремнезема в пробах руды (%)",
            "expression": "AVERAGE(fact_ore_quality[sio2_content])",
            "formatString": "0.00",
            "lineageTag": "msr-014",
            "annotations": [
              {
                "name": "Category",
                "value": "Качество"
              }
            ]
          },
          {
            "name": "Средняя влажность руды",
            "description": "Средний процент влажности в пробах руды",
            "expression": "AVERAGE('fact_ore_quality'[moisture])",
            "formatString": "0.00\"%\"",
            "lineageTag": "msr-015",
            "annotations": [
              {
                "name": "Category",
                "value": "Качество"
              }
            ]
          }
        ],
        "annotations": [
          {
            "name": "DisplayName",
            "value": "Показатели (KPI)"
          }
        ]
      }
    ],
